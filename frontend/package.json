{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve design-lab",
    "start:patient": "ng serve patient-portal",
    "start:staff": "ng serve staff-portal",
    "start:design": "ng serve design-lab",
    "api:lint": "redocly lint salud-nexus@v1 --config redocly.yaml",
    "api:generate": "orval --config orval.config.mjs --fail-on-warnings",
    "api:check": "npm run api:lint && node scripts/check-generated-api.mjs",
    "build": "npm run build:libs && npm run build:apps",
    "build:libs": "ng build design-system && ng build api-client && ng build auth && ng build shared && ng build motion",
    "build:apps": "ng build patient-portal && ng build staff-portal && ng build design-lab",
    "test": "npm run test:unit",
    "test:unit": "npm run build:libs && npm run test:unit:projects",
    "test:unit:projects": "ng test patient-portal --watch=false && ng test staff-portal --watch=false && ng test design-lab --watch=false && ng test design-system --watch=false && ng test api-client --watch=false && ng test auth --watch=false && ng test shared --watch=false && ng test motion --watch=false",
    "test:e2e": "npm run build:libs && playwright test",
    "test:e2e:design": "npm run build:libs && playwright test --project=chromium-desktop --project=chromium-mobile",
    "test:e2e:patient": "npm run build:libs && playwright test --project=patient-chromium-desktop --project=patient-chromium-mobile",
    "test:e2e:staff": "npm run build:libs && playwright test --project=staff-chromium-desktop --project=staff-chromium-mobile",
    "lint": "ng lint patient-portal && ng lint staff-portal && ng lint design-lab && ng lint design-system && ng lint api-client && ng lint auth && ng lint shared && ng lint motion",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "audit": "npm audit --audit-level=high && npm audit signatures",
    "verify": "npm run api:check && npm run format:check && npm run lint && npm run test:unit && npm run build && npm run test:e2e && npm run audit"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/aria": "^22.0.5",
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@fontsource-variable/manrope": "^5.3.0",
    "@fontsource-variable/source-sans-3": "^5.3.0",
    "@fontsource/material-symbols-rounded": "^5.3.0",
    "gsap": "^3.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@redocly/cli": "2.40.0",
    "angular-eslint": "^22.1.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "orval": "8.22.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "@hono/node-server": "2.0.11"
    },
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0",
    "vite": "7.3.6"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@parcel/watcher": false,
    "lmdb": false,
    "msgpackr-extract": false
  }
}
