{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/design-system",
  "assets": [
    {
      "glob": "**/*.scss",
      "input": "src/styles",
      "output": "styles"
    }
  ],
  "lib": {
    "entryFile": "src/public-api.ts",
    "styleIncludePaths": ["src/styles"]
  }
}
