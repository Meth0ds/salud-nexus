# Copia este archivo a infrastructure/.env o usa scripts/Start-Local.ps1,
# que genera los cuatro secretos con un generador criptografico sin mostrarlos.
COMPOSE_PROJECT_NAME=salud-nexus

APP_ENV=local
APP_URL=http://localhost:8080
APP_KEY=
AUDIT_INTEGRITY_KEY=

POSTGRES_DB=salud_nexus
POSTGRES_USER=salud_nexus_app
POSTGRES_PASSWORD=
REDIS_PASSWORD=

API_HOST_PORT=8080
PATIENT_HOST_PORT=4200
STAFF_HOST_PORT=4201
DESIGN_HOST_PORT=4300

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4300
TRUSTED_HOSTS=localhost,127.0.0.1,patient-web,staff-web,design-lab,api-proxy
